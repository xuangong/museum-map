{
  "name": "museum-map",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 4242",
    "local": "bun --hot run src/local.ts",
    "predev": "wrangler d1 migrations apply museum-map-db --local",
    "deploy": "wrangler deploy",
    "seed": "bun run scripts/seed.ts",
    "init": "bun run scripts/init.ts",
    "snapshot": "bun run scripts/snapshot.ts",
    "restore": "bun run scripts/restore.ts",
    "scrape-images": "bun run scripts/scrape-images.ts --",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/bun": "latest",
    "miniflare": "^4.20260430.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.78.0"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@types/qrcode": "^1.5.6",
    "cheerio": "^1.2.0",
    "elysia": "^1.4.28",
    "pinyin-pro": "^3.28.1",
    "qrcode": "^1.5.4",
    "yaml": "^2.8.4"
  }
}
